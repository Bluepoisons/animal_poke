# ============================================================
# 客户端配置示例(非敏感)
# 复制本文件为 .env 后填入本地值; .env 已被根 .gitignore 忽略, 切勿提交真实值。
#
# 重要: 第三方 Key(腾讯地图 / 彩云天气 / 云端 VLM / 云端 LLM)
# 全部存放在 Go 后端 .env(见 backend/.env.example), 客户端永不含第三方 Key。
# ============================================================

# Go 后端基础地址(含协议与端口), 客户端仅与此地址通信
BACKEND_BASE_URL=http://127.0.0.1:8080

# 可选: 日志级别(DEBUG / INFO / WARN / ERROR), 默认 INFO
LOG_LEVEL=INFO

# 可选: 本地数据库文件名(相对 user://), 默认 animal_poke.db
DB_FILENAME=animal_poke.db
