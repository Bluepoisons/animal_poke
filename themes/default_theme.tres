[gd_resource type="Theme" load_steps=6 format=3]

; default_theme.tres — 全局 UI 主题
; 参考: 游戏开发计划.md 5.1 稀有度视觉标识、Task F2
; 通过 project.godot [gui] theme/custom 全局应用。
; 稀有度边框色单独由 scripts/ui/rarity.gd 管理(灰/绿/蓝/紫/金)。
; 自定义字体待美术阶段补充, 当前用引擎默认字体。

; 配色: 深色面板 + 蓝绿强调色(accent #2EA88A), 适合移动端游戏 UI。

[sub_resource type="StyleBoxFlat" id="sb_button_normal"]
bg_color = Color(0.165, 0.165, 0.208, 1)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8
content_margin_left = 16.0
content_margin_top = 8.0
content_margin_right = 16.0
content_margin_bottom = 8.0

