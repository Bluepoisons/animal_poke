[sub_resource type="StyleBoxFlat" id="sb_panel"]
bg_color = Color(0.118, 0.118, 0.141, 0.941)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.227, 0.227, 0.271, 1)
corner_radius_top_left = 12
corner_radius_top_right = 12
corner_radius_bottom_right = 12
corner_radius_bottom_left = 12
content_margin_left = 12.0
content_margin_top = 12.0
content_margin_right = 12.0
content_margin_bottom = 12.0

[resource]
default_font_size = 16
Button/colors/font_color = Color(1, 1, 1, 1)
Button/colors/font_hover_color = Color(1, 1, 1, 1)
Button/colors/font_pressed_color = Color(0.05, 0.05, 0.05, 1)
Button/colors/font_disabled_color = Color(0.5, 0.5, 0.55, 1)
Button/colors/font_focus_color = Color(1, 1, 1, 1)
Button/styles/normal = SubResource("sb_button_normal")
Button/styles/hover = SubResource("sb_button_hover")
Button/styles/pressed = SubResource("sb_button_pressed")
Button/styles/disabled = SubResource("sb_button_disabled")
Button/styles/focus = SubResource("sb_button_normal")
Button/constants/h_separation = 8
Panel/styles/panel = SubResource("sb_panel")
Label/colors/font_color = Color(1, 1, 1, 1)
Label/colors/font_outline_color = Color(0, 0, 0, 0.6)
Label/constants/outline_size = 2
LineEdit/colors/font_color = Color(1, 1, 1, 1)
