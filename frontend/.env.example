# 仅公开配置，禁止放入任何第三方 Key / JWT Secret
# 复制: cp .env.example .env

# API 根地址（不要尾斜杠）
# - 本地开发：留空，走 Vite /api 代理到 localhost:8080
# - 生产镜像：推荐留空，走 Nginx 同域 /api 反代到 animal-poke-backend
# - 仅当需要跨域绝对地址时设置，例如 https://api.animal-poke.example.com
#   （同时需在 CSP connect-src 中显式放行该 host）
VITE_API_BASE_URL=

# 运行时覆盖（生产容器）：/config.js 中 window.__AP_CONFIG__.apiBaseUrl
# 由 deploy/docker-entrypoint.d/40-ap-runtime-config.sh 根据 API_BASE_URL 生成

# 日志级别（可选）
VITE_LOG_LEVEL=INFO
