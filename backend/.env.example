# ============================================================
# Go 后端配置示例(含第三方 Key 字段)
# 复制为 .env 后填入真实值; .env 已在 backend/.gitignore 忽略, 切勿提交真实 Key。
#
# 关键: 客户端永不含这些第三方 Key, 全部经后端代理调用(F6 / 4.6.1 Key 管理规范)。
# ============================================================

# 服务
SERVER_ADDR=:8080
LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production

# MySQL(本地 Docker 开发服务器, 见 docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=animal_poke
DB_PASSWORD=animal_poke
DB_NAME=animal_poke

# 第三方 Key(真实值请勿提交)
TENCENT_MAP_KEY=
CAIYUN_WEATHER_KEY=
LLM_ENDPOINT=
LLM_KEY=
LLM_MODEL=
