# 复制为 .env 后填写（切勿提交真实密钥）

APP_ENV=development
SERVER_ADDR=:8080
LOG_LEVEL=INFO

# 开发可用默认值；生产必须替换为强随机密钥（>=32）
JWT_SECRET=animal-poke-dev-secret
JWT_ISSUER=animal-poke
JWT_AUDIENCE=animal-poke-client
JWT_ACCESS_TTL=2h

# 开发可开启 mock；生产强制关闭
AI_MOCK_ENABLED=true

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=animal_poke
DB_PASSWORD=animal_poke
DB_NAME=animal_poke
DB_TLS=false

# 生产必须配置 CORS 白名单与 Admin API Key
# CORS_ALLOWED_ORIGINS=https://app.example.com
# ADMIN_API_KEY=
# OPS_TOKEN=   # 可选；未设置时回退 ADMIN_API_KEY（X-AP-Ops-Token）

# 产品 feature flags（AP-042）
# production 默认 false；development 默认 true。显式设置可覆盖。
# FEATURE_RANKING=false
# FEATURE_PVP=false
# FEATURE_SOCIAL=false
# FEATURE_OPS=false

# 商业化（production 默认关闭）
# COMMERCE_ENABLED=false
# COMMERCE_STORE_VERIFY=false

# 可选共享限流（未配置则内存实现）
REDIS_URL=

# 第三方 Key（真实值请勿提交）
TENCENT_MAP_KEY=
CAIYUN_WEATHER_KEY=

# Vision（检测/分析）— 原子三元组：ENDPOINT + KEY + MODEL 必须同时配置或同时为空
# 禁止 VISION/VLM/LLM 字段级混合；默认不会回退到 LLM_*
VISION_ENDPOINT=
VISION_KEY=
VISION_MODEL=
# 兼容旧名：可使用完整 VLM_* 三元组代替 VISION_*（仍禁止混用）
# VLM_ENDPOINT=
# VLM_KEY=
# VLM_MODEL=
# 若确需复用 LLM 整组配置，必须显式开启（默认 false）
# VISION_REUSE_LLM=true

# Text/LLM（数值生成）— 独立三元组，不会自动充当 Vision
LLM_ENDPOINT=
LLM_KEY=
LLM_MODEL=
