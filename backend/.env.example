# ============================================================
# Go 后端配置示例(含第三方 Key 字段)
# 复制为 .env 后填入真实值; .env 已在 backend/.gitignore 忽略, 切勿提交真实 Key。
#
# 关键: 客户端永不含这些第三方 Key, 全部经后端代理调用。
# ============================================================

# 环境: development | production
APP_ENV=development
AI_MOCK_ENABLED=true

# 服务
SERVER_ADDR=:8080
LOG_LEVEL=INFO
JWT_SECRET=change-me-in-production-use-32chars-min
JWT_ISSUER=animal-poke
JWT_AUDIENCE=animal-poke-client
JWT_ACCESS_TTL=2h
ADMIN_API_KEY=

# HTTP 超时
HTTP_READ_HEADER_TIMEOUT=5s
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=60s
HTTP_IDLE_TIMEOUT=90s
HTTP_SHUTDOWN_TIMEOUT=15s

# 图片限制
MAX_IMAGE_BYTES=5242880
MAX_IMAGE_PIXELS=12000000

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=animal_poke
DB_PASSWORD=animal_poke
DB_NAME=animal_poke
DB_TLS=false
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=10m
# 生产建议 AUTO_MIGRATE=false，由 Job 执行迁移
AUTO_MIGRATE=true

# 可选共享限流（未配置则内存实现）
REDIS_URL=

# 第三方 Key（真实值请勿提交）
TENCENT_MAP_KEY=
CAIYUN_WEATHER_KEY=

# Vision（检测/分析）— 可与 LLM 指向同一供应商
VISION_ENDPOINT=
VISION_KEY=
VISION_MODEL=

# Text/LLM（数值生成）
LLM_ENDPOINT=
LLM_KEY=
LLM_MODEL=
