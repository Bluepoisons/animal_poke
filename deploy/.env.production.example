# Copy to deploy/.env.production, fill every required value, then chmod 600.

BACKEND_IMAGE=docker.cnb.cool/pvzcs/docker-images:animal-poke-backend
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8080
MYSQL_IMAGE=mysql:8.0

MYSQL_ROOT_PASSWORD=
DB_NAME=animal_poke
DB_USER=animal_poke
DB_PASSWORD=

# Generate each value independently: openssl rand -base64 48
JWT_SIGNING_KEY=
ACCOUNT_TOKEN_PEPPER=
STATS_HMAC_KEY=
TIME_SIGNING_KEY=
ADMIN_JWT_SECRET=
ADMIN_API_KEY=
ADMIN_BREAK_GLASS_ENABLED=false

AI_ENDPOINT=
AI_KEY=
AI_MODEL=

TENCENT_MAP_KEY=
TENCENT_MAP_SK=
CAIYUN_WEATHER_KEY=

# Exact frontend origin(s), comma-separated. Example: https://animal.example.com
CORS_ALLOWED_ORIGINS=
# Reverse proxy CIDR/IP, comma-separated. Leave empty when binding directly to localhost.
TRUSTED_PROXIES=

LOG_LEVEL=INFO
AUTO_MIGRATE=true
FEATURE_RANKING=false
FEATURE_PVP=false
FEATURE_SOCIAL=false
FEATURE_OPS=false
COMMERCE_ENABLED=false
COMMERCE_STORE_VERIFY=false
RELEASE_SHA=
